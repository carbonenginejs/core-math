{
  "name": "@carbonenginejs/core-math",
  "version": "0.1.5",
  "description": "Browser-friendly gl-matrix based math containers and CarbonEngineJS mesh/tangent helpers.",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./is": "./src/is.js",
    "./num": "./src/num.js",
    "./vec2": "./src/vec2.js",
    "./vec3": "./src/vec3.js",
    "./vec4": "./src/vec4.js",
    "./quat": "./src/quat.js",
    "./mat3": "./src/mat3.js",
    "./mat4": "./src/mat4.js",
    "./box3": "./src/box3.js",
    "./tri3": "./src/tri3.js",
    "./lne3": "./src/lne3.js",
    "./pln": "./src/pln.js",
    "./ray3": "./src/ray3.js",
    "./sph3": "./src/sph3.js",
    "./pool": "./src/pool.js",
    "./utils": "./src/utils.js",
    "./noise": "./src/noise.js",
    "./curve": "./src/curve.js",
    "./vertex": "./src/vertex.js",
    "./mesh": "./src/mesh.js",
    "./tangent": "./src/tangent.js",
    "./geometry": "./src/geometry/index.js",
    "./types": "./src/types.ts"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test",
    "lint": "eslint --ext .js,.mjs src test",
    "lint:fix": "eslint --fix --ext .js,.mjs src test"
  },
  "keywords": [
    "carbonenginejs",
    "core-math",
    "gl-matrix",
    "geometry",
    "tangent",
    "mesh",
    "browser"
