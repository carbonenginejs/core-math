  "files": [
    "src",
    "README.md",
    "LICENSE",
    "NOTICE",
    "THIRD-PARTY-NOTICES.md"
  ],
  "license": "MIT",
  "dependencies": {
    "gl-matrix": "^3.4.4"
  },
  "devDependencies": {
    "eslint": "^8.57.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carbonenginejs/core-math.git"
  },
  "homepage": "https://github.com/carbonenginejs/core-math#readme",
  "bugs": {
    "url": "https://github.com/carbonenginejs/core-math/issues"
  },
  "publishConfig": {
    "access": "public"
  }
